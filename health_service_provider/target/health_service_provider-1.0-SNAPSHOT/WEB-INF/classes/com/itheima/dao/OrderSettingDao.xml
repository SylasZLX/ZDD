<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >


<mapper namespace="com.itheima.dao.OrderSettingDao">
    <select id="findCountByOrderDate" parameterType="java.util.Date" resultType="long">
        SELECT count(*) FROM t_ordersetting WHERE orderDate = #{orderDate}
    </select>

    <select id="findByReservations" parameterType="java.util.Date" resultType="Integer">
        SELECT reservations FROM t_ordersetting WHERE orderDate = #{orderDate}
    </select>

    <update id="editNumberByOrderDate" parameterType="com.itheima.pojo.OrderSetting">
        UPDATE t_ordersetting SET number = #{number} WHERE orderDate = #{orderDate}
    </update>

    <insert id="add" parameterType="com.itheima.pojo.OrderSetting">
        INSERT INTO t_ordersetting (number, orderDate) VALUES (#{number}, #{orderDate})
    </insert>

    <select id="getOrderSettingByMonth" parameterType="java.util.Map" resultType="com.itheima.pojo.OrderSetting">
        SELECT * FROM t_ordersetting WHERE orderDate BETWEEN #{begin} AND #{end}
    </select>
</mapper>