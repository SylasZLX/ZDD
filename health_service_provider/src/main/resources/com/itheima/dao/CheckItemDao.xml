<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.itheima.dao.CheckItemDao">
    <insert id="add" parameterType="com.itheima.pojo.CheckItem">
        insert into t_checkitem(code,name,sex,age,price,type,attention,remark)
        values(#{code},#{name},#{sex},#{age},#{price},#{type},#{attention},#{remark})
    </insert>

    <!-- 查询检查项 -->
    <select id="findByCondition" parameterType="String" resultType="com.itheima.pojo.CheckItem">
        select * from t_checkitem
        <if test="value != null and value.length > 0">
            where code = #{value} OR name = #{value}
        </if>
    </select>

    <!--  编辑检查项1  -->
    <select id="findById" parameterType="int" resultType="com.itheima.pojo.CheckItem">
        select * from t_checkitem where id = #{id}
    </select>

    <!-- 编辑检查项2 -->
    <update id="edit" parameterType="com.itheima.pojo.CheckItem">
        update t_checkitem
        <set>
            <if test="code != null">
                code = #{code},
            </if>
            <if test="code != null">
                name = #{name},
            </if>
            <if test="code != null">
                sex = #{sex},
            </if>
            <if test="code != null">
                age = #{age},
            </if>
            <if test="code != null">
                price = #{price},
            </if>
            <if test="code != null">
                type = #{type},
            </if>
            <if test="code != null">
                attention = #{attention},
            </if>
            <if test="code != null">
                remark = #{remark},
            </if>
        </set>
        where id = #{id}
    </update>

    <select id="selectCountByCheckItemId" parameterType="int" resultType="long">
       SELECT count(1) FROM t_checkgroup_checkitem where checkitem_id = #{checkitem_id}
    </select>

    <delete id="deleteById" parameterType="int">
        delete from t_checkitem where id = #{id}
    </delete>

    <!-- 查询所有检查项-->
    <select id="findAllCheckItem" resultType="com.itheima.pojo.CheckItem">
        select *from t_checkitem
    </select>
</mapper>
